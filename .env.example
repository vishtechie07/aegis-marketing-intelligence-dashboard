# Copy this file to .env and fill in your values
# Do NOT commit .env to version control

# PostgreSQL (used by docker-compose)
POSTGRES_PASSWORD=aegis_secret

# OpenAI API key (optional for Docker; can also set via Settings in the app)
OPENAI_API_KEY=

# Comma-separated list of competitors to track
TRACKED_COMPETITORS=Microsoft,Google,Amazon,OpenAI,Anthropic
